DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
SESSION_SECRET="replace-with-openssl-rand-base64-32"
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"
SUPABASE_STORAGE_BUCKET="work-order-files"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
MAX_UPLOAD_MB="8"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="replace-with-web-push-public-key"
VAPID_PRIVATE_KEY="replace-with-web-push-private-key"
VAPID_SUBJECT="mailto:admin@example.com"
CRON_SECRET="replace-with-openssl-rand-hex-32"

# Dùng khi chưa có DB/Supabase để xem chức năng bằng dữ liệu ảo.
# Tài khoản demo: admin@demo.local / dispatch@demo.local / minh@demo.local / accounting@demo.local
# Mật khẩu chung: demo1234
CCTV_DATA_MODE="mock"
